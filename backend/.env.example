# Application Configurations
PROJECT_NAME="NextRound"
ENV="development"
DEBUG=true

# Database Configurations
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/nextround"

# Redis Configurations
REDIS_URL="redis://localhost:6379/0"

# External Integrations
LITELLM_GEMINI_API_KEY=""
LITELLM_GROQ_API_KEY=""
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
JUDGE0_URL="http://localhost:2358"
JUDGE0_API_KEY=""

# JWT Security Configurations
SECRET_KEY="supersecretkey_change_me_in_production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER="nextround-api"
JWT_AUDIENCE="nextround-app"

# LLM Configurations (Deprecated - Configuration is now handled in configs/llm_profiles.yaml)
# LLM_PROVIDER="gemini"
# LLM_MODEL="gemini/gemini-2.5-flash"
# LLM_TEMPERATURE=0.0
# LLM_MAX_TOKENS=4096
# LLM_TIMEOUT=30
GEMINI_API_KEY=""  # Google Gemini API key
GROQ_API_KEY=""
MISTRAL_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"
